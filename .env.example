# Google Maps API Key (get from https://console.cloud.google.com/)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Database Configuration
DATABASE_PATH=data/nyc_property_data.db
DATABASE_URL=sqlite:///data/nyc_property_data.db

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log

# NYC Geographic Boundaries
NYC_LAT_MIN=40.4774
NYC_LAT_MAX=40.9176  
NYC_LNG_MIN=-74.2591
NYC_LNG_MAX=-73.7004

# API Rate Limiting
API_DELAY_SECONDS=0.1
MAX_RETRIES=3

# Model Configuration
MODEL_SAVE_PATH=models/saved_models/
RANDOM_STATE=42

# Optional: External APIs
ZILLOW_API_KEY=your_zillow_key_if_available
REDFIN_API_KEY=your_redfin_key_if_available
WALKSCORE_API_KEY=your_walkscore_key_if_available
